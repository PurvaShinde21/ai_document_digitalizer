# ──────────────────────────────────────────────
# Environment Variables
# ──────────────────────────────────────────────
.env
.env.local
.env.*
!.env.example

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
.venv/
venv/
env/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ──────────────────────────────────────────────
# Node / Next.js
# ──────────────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────
# ML Model Artifacts (large binary files)
# ──────────────────────────────────────────────
*.bin
*.pt
*.ckpt
*.safetensors
*.pth
*.onnx

# HuggingFace cache (can be 1-5 GB)
.cache/
huggingface/

# ──────────────────────────────────────────────
# Storage Directories (user uploads & outputs)
# ──────────────────────────────────────────────
storage/uploads/
storage/outputs/
worker/storage/

# ──────────────────────────────────────────────
# Data / Datasets (never commit raw data)
# ──────────────────────────────────────────────
data/
datasets/
experiments/data/
*.csv
*.parquet
*.jsonl

# ──────────────────────────────────────────────
# OS / Editor
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
