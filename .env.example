# ──────────────────────────────────────────────
# AI Document Digitizer — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Backend (FastAPI) ─────────────────────────
# Secret key for signing tokens / sessions
SECRET_KEY=your-secret-key-here

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Maximum upload file size in megabytes
MAX_UPLOAD_SIZE_MB=20

# ── Redis ─────────────────────────────────────
# Connection URL for the Redis instance
REDIS_URL=redis://localhost:6379/0

# ── Storage ───────────────────────────────────
# Local storage paths (used in development)
UPLOAD_DIR=worker/storage/uploads
OUTPUT_DIR=worker/storage/outputs

# AWS S3 / Cloudflare R2 (used in production)
S3_BUCKET_NAME=your-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ── ML Worker ─────────────────────────────────
# HuggingFace model identifier for TrOCR
TROCR_MODEL=microsoft/trocr-base-handwritten

# ── Frontend (Next.js) ────────────────────────
# Public URL of the FastAPI backend (used by browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
