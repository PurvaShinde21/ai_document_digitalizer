# ──────────────────────────────────────────────────────────────────────────────
# AI Document Digitizer — Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── General ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Max upload file size in megabytes (images or PDFs)
MAX_UPLOAD_SIZE_MB=20

# ── HuggingFace Inference API (FREE — no GPU, no model download) ──────────────
# Get your free token at: https://huggingface.co/settings/tokens
# Free tier: 30,000 requests/month
HF_API_TOKEN=hf_your_token_here

# trocr-small-handwritten = 270 MB (5x smaller than base, same free API)
TROCR_MODEL=microsoft/trocr-small-handwritten

# ── Redis (Upstash — FREE tier) ───────────────────────────────────────────────
# Local dev:   redis://localhost:6379/0
# Upstash prod: rediss://:password@host.upstash.io:6379
# Sign up free at: https://upstash.com
REDIS_URL=redis://localhost:6379/0

# ── Local Storage (dev) ───────────────────────────────────────────────────────
UPLOAD_DIR=storage/uploads
OUTPUT_DIR=storage/outputs

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Public URL of the FastAPI backend (seen by the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
